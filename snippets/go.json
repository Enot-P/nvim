{
  "Error wrap": {
    "prefix": "erw",
    "body": [
      "if err != nil {",
      "\treturn fmt.Errorf(\"${1:msg}: %w\", err)",
      "}"
    ]
  },
  "Context arg": {
    "prefix": "ctx",
    "body": [
      "ctx context.Context"
    ]
  },
  "Interface method": {
    "prefix": "im",
    "body": [
      "${1:MethodName}(${2:arg} ${3:Type}) (${4:ReturnType}, error)"
    ]
  },
  "If err return": {
    "prefix": "iferr",
    "body": [
      "if err != nil {",
      "\t$0",
      "\treturn",
      "}"
    ]
  },
  "Middleware type": {
    "prefix": "mwtype",
    "body": [
      "type Middleware func(http.Handler) http.Handler"
    ]
  },
  "Middleware func": {
    "prefix": "mw",
    "body": [
      "func ${1:Name}(next http.Handler) http.Handler {",
      "\treturn http.HandlerFunc(func(w http.ResponseWriter, r *http.Request) {",
      "\t\t$0",
      "\t\tnext.ServeHTTP(w, r)",
      "\t})",
      "}"
    ]
  },
  "Middleware func with deps": {
    "prefix": "mwd",
    "body": [
      "func ${1:Name}(${2:dep} ${3:Type}) Middleware {",
      "\treturn func(next http.Handler) http.Handler {",
      "\t\treturn http.HandlerFunc(func(w http.ResponseWriter, r *http.Request) {",
      "\t\t\t$0",
      "\t\t\tnext.ServeHTTP(w, r)",
      "\t\t})",
      "\t}",
      "}"
    ]
  },
  "Middleware chain helper": {
    "prefix": "mwchain",
    "body": [
      "func Chain(h http.Handler, middlewares ...Middleware) http.Handler {",
      "\tfor i := len(middlewares) - 1; i >= 0; i-- {",
      "\t\th = middlewares[i](h)",
      "\t}",
      "\treturn h",
      "}"
    ]
  },
  "Chain apply": {
    "prefix": "chain",
    "body": [
      "${1:handler} = Chain(${1:handler}, ${0:mw1, mw2})"
    ]
  }
}
